#!/usr/bin/env bash
# Set up GitHub Actions CI/CD for deploying to EKS.
#
# Creates an IAM role with OIDC trust for a GitHub repo, grants ECR push
# and EKS deploy access, and stores the role ARN as a GitHub secret.
#
# Usage:
#   ./bin/setup-ci-cd \
#     --repo tokonoma-ai/microservices-demo \
#     --branch master \
#     --cluster tokonoma \
#     --namespace sock-shop \
#     --region us-west-2
#
# Prerequisites:
#   - AWS CLI configured with admin-level access
#   - gh CLI authenticated
#   - GitHub OIDC provider already registered in the AWS account
#     (run with --setup-oidc on first use per account)
#
set -euo pipefail

# --- Parse arguments ----------------------------------------------------------

REPO=""
BRANCH="main"
CLUSTER=""
NAMESPACE=""
REGION="us-west-2"
SETUP_OIDC=false
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)        REPO="$2"; shift 2 ;;
    --branch)      BRANCH="$2"; shift 2 ;;
    --cluster)     CLUSTER="$2"; shift 2 ;;
    --namespace)   NAMESPACE="$2"; shift 2 ;;
    --region)      REGION="$2"; shift 2 ;;
    --setup-oidc)  SETUP_OIDC=true; shift ;;
    --dry-run)     DRY_RUN=true; shift ;;
    *)             echo "Unknown argument: $1"; exit 1 ;;
  esac
done

for var in REPO CLUSTER NAMESPACE; do
  if [[ -z "${!var}" ]]; then
    echo "Error: --$(echo $var | tr '[:upper:]' '[:lower:]') is required"
    echo "Usage: $0 --repo OWNER/REPO --cluster NAME --namespace NAME [--branch BRANCH] [--region REGION] [--setup-oidc] [--dry-run]"
    exit 1
  fi
done

AWS_ACCOUNT=$(aws sts get-caller-identity --query Account --output text)
REPO_SHORT=$(echo "$REPO" | tr '/' '-')
ROLE_NAME="github-actions-${REPO_SHORT}"

echo "============================================================================="
echo "CI/CD Setup"
echo "  Repo:       ${REPO} (branch: ${BRANCH})"
echo "  AWS:        ${AWS_ACCOUNT} / ${REGION}"
echo "  Cluster:    ${CLUSTER}"
echo "  Namespace:  ${NAMESPACE}"
echo "  Role:       ${ROLE_NAME}"
echo "============================================================================="
echo ""

run() {
  echo "  \$ $*"
  if [[ "$DRY_RUN" == "true" ]]; then
    echo "  (dry-run: skipped)"
  else
    "$@"
  fi
}

# --- Step 1: OIDC provider (one-time per AWS account) ------------------------

if [[ "$SETUP_OIDC" == "true" ]]; then
  echo "==> Step 1: Registering GitHub OIDC provider..."
  run aws iam create-open-id-connect-provider \
    --url https://token.actions.githubusercontent.com \
    --client-id-list sts.amazonaws.com \
    --thumbprint-list 6938fd4d98bab03faadb97b34396831e3780aea1 \
    2>/dev/null || echo "  (already exists)"
  echo ""
fi

# --- Step 2: IAM role with OIDC trust ----------------------------------------

echo "==> Step 2: Creating IAM role ${ROLE_NAME}..."

TRUST_POLICY=$(cat <<POLICY
{
  "Version": "2012-10-17",
  "Statement": [{
    "Effect": "Allow",
    "Principal": {
      "Federated": "arn:aws:iam::${AWS_ACCOUNT}:oidc-provider/token.actions.githubusercontent.com"
    },
    "Action": "sts:AssumeRoleWithWebIdentity",
    "Condition": {
      "StringEquals": {
        "token.actions.githubusercontent.com:aud": "sts.amazonaws.com"
      },
      "StringLike": {
        "token.actions.githubusercontent.com:sub": "repo:${REPO}:ref:refs/heads/${BRANCH}"
      }
    }
  }]
}
POLICY
)

if aws iam get-role --role-name "$ROLE_NAME" &>/dev/null; then
  echo "  Role exists. Updating trust policy..."
  run aws iam update-assume-role-policy \
    --role-name "$ROLE_NAME" \
    --policy-document "$TRUST_POLICY"
else
  run aws iam create-role \
    --role-name "$ROLE_NAME" \
    --assume-role-policy-document "$TRUST_POLICY" \
    --query 'Role.Arn' --output text
fi
echo ""

# --- Step 3: ECR push permissions --------------------------------------------

echo "==> Step 3: Attaching ECR push policy..."
run aws iam attach-role-policy \
  --role-name "$ROLE_NAME" \
  --policy-arn arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryPowerUser
echo ""

# --- Step 4: EKS describe permission -----------------------------------------

echo "==> Step 4: Adding EKS describe permission..."
CLUSTER_ARN="arn:aws:eks:${REGION}:${AWS_ACCOUNT}:cluster/${CLUSTER}"
run aws iam put-role-policy \
  --role-name "$ROLE_NAME" \
  --policy-name eks-deploy \
  --policy-document "{
    \"Version\": \"2012-10-17\",
    \"Statement\": [{
      \"Effect\": \"Allow\",
      \"Action\": [\"eks:DescribeCluster\"],
      \"Resource\": \"${CLUSTER_ARN}\"
    }]
  }"
echo ""

# --- Step 5: EKS access entry ------------------------------------------------

echo "==> Step 5: Creating EKS access entry..."
ROLE_ARN="arn:aws:iam::${AWS_ACCOUNT}:role/${ROLE_NAME}"

if aws eks describe-access-entry --cluster-name "$CLUSTER" --principal-arn "$ROLE_ARN" &>/dev/null; then
  echo "  (access entry already exists)"
else
  run aws eks create-access-entry \
    --cluster-name "$CLUSTER" \
    --principal-arn "$ROLE_ARN" \
    --type STANDARD
fi

echo "  Associating namespace-scoped edit policy..."
run aws eks associate-access-policy \
  --cluster-name "$CLUSTER" \
  --principal-arn "$ROLE_ARN" \
  --policy-arn arn:aws:eks::aws:cluster-access-policy/AmazonEKSEditPolicy \
  --access-scope "type=namespace,namespaces=${NAMESPACE}"
echo ""

# --- Step 6: GitHub secret ----------------------------------------------------

echo "==> Step 6: Setting AWS_ROLE_ARN secret on ${REPO}..."
ROLE_ARN="arn:aws:iam::${AWS_ACCOUNT}:role/${ROLE_NAME}"
if [[ "$DRY_RUN" == "true" ]]; then
  echo "  (dry-run) gh secret set AWS_ROLE_ARN --repo ${REPO} --body ${ROLE_ARN}"
else
  gh secret set AWS_ROLE_ARN --repo "$REPO" --body "$ROLE_ARN"
fi
echo ""

# --- Done ---------------------------------------------------------------------

echo "============================================================================="
echo "Setup complete."
echo ""
echo "  Role ARN:  ${ROLE_ARN}"
echo "  Cluster:   ${CLUSTER} (namespace: ${NAMESPACE})"
echo "  Secret:    AWS_ROLE_ARN set on ${REPO}"
echo ""
echo "Next: add a .github/workflows/build-and-update.yaml to the repo."
echo "See docs/ci-cd-setup.md for the workflow template."
echo "============================================================================="
