#!/bin/bash
#
# Deploy Sock Shop to Kubernetes using Kustomize.
# Uses official weaveworksdemos/* images (default overlay) or custom images (dev overlay).
#
# Usage:
#   ./bin/deploy              # deploy with official images (overlay: default)
#   ./bin/deploy dev          # deploy with tag "dev" for all app images (overlay: dev)
#   OVERLAY=dev ./bin/deploy   # same as ./bin/deploy dev
#
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
KUSTOMIZE_ROOT="${REPO_ROOT}/deploy/kubernetes"
NAMESPACE="sock-shop"

# Overlay: default (official images) or dev (tag "dev" for app images)
OVERLAY="${1:-${OVERLAY:-default}}"
OVERLAY_PATH="${KUSTOMIZE_ROOT}/overlays/${OVERLAY}"

if [[ ! -d "${OVERLAY_PATH}" ]]; then
  echo "Unknown overlay: ${OVERLAY}" >&2
  echo "Available: default, dev" >&2
  echo "  default - official weaveworksdemos/* images from Docker Hub" >&2
  echo "  dev     - same images with tag 'dev' (for locally built images)" >&2
  exit 1
fi

echo "Deploying Sock Shop from microservices-demo (${REPO_ROOT})..."
echo "Overlay: ${OVERLAY}"
echo ""

echo "Applying with Kustomize (kubectl apply -k ${OVERLAY_PATH})..."
kubectl apply -k "${OVERLAY_PATH}"

echo ""
echo "Waiting for deployments to roll out..."
for dep in carts catalogue orders front-end payment user shipping queue-master load-generator; do
  echo "  Waiting for ${dep}..."
  kubectl rollout status deployment/"${dep}" -n "${NAMESPACE}" --timeout=180s 2>/dev/null || \
    echo "  WARNING: ${dep} did not become ready within 180s"
done

echo ""
echo "Deployment complete."
echo ""
echo "Current status:"
kubectl get pods -n "${NAMESPACE}"
echo ""
echo "To access the front-end:"
echo "  NodePort: http://<node-ip>:30001"
echo "  Or: ./bin/port-forward"
echo "  Then open http://localhost:8080"
