#!/bin/bash
# Deploy Sock Shop to Kubernetes using Kustomize.
# Reads .build-manifest.json to determine per-service image tags.
#
# Usage:
#   ./bin/deploy --kind         Deploy to kind cluster (local dev images)
#   ./bin/deploy --eks          Deploy to EKS (ECR dev images)
#   ./bin/deploy --gke          Deploy to GKE (Artifact Registry dev images)
#
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
MANIFEST="${REPO_ROOT}/.build-manifest.json"
NAMESPACE="sock-shop"
APP_DEPLOYMENTS=(carts catalogue orders front-end payment user shipping queue-master)

# --- Parse arguments ----------------------------------------------------------

TARGET=""
for arg in "$@"; do
  case "$arg" in
    --kind) TARGET="kind" ;;
    --eks)  TARGET="eks" ;;
    --gke)  TARGET="gke" ;;
    *)      echo "Unknown argument: $arg"; echo "Usage: $0 --kind | --eks | --gke"; exit 1 ;;
  esac
done

if [[ -z "$TARGET" ]]; then
  echo "Error: specify --kind, --eks, or --gke"
  echo "Usage: $0 --kind | --eks | --gke"
  exit 1
fi

# --- Read build manifest ------------------------------------------------------

if [[ ! -f "$MANIFEST" ]]; then
  echo "Error: .build-manifest.json not found. Run ./bin/build --${TARGET} first."
  exit 1
fi

MANIFEST_TARGET=$(python3 -c "import json; print(json.load(open('${MANIFEST}'))['target'])")
MANIFEST_TAG=$(python3 -c "import json; print(json.load(open('${MANIFEST}'))['tag'])")
MANIFEST_SHA=$(python3 -c "import json; print(json.load(open('${MANIFEST}'))['git_sha'])")

if [[ "$MANIFEST_TARGET" != "$TARGET" ]]; then
  echo "Warning: manifest was built for '${MANIFEST_TARGET}' but deploying to '${TARGET}'."
  echo "Run ./bin/build --${TARGET} to rebuild for the correct target."
  exit 1
fi

echo "Deploying Sock Shop (target: ${TARGET})"
echo "  Manifest: ${MANIFEST_TAG} (${MANIFEST_SHA})"
echo ""

# --- Generate kustomization.yaml from manifest --------------------------------

OVERLAY="${REPO_ROOT}/deploy/kubernetes/overlays/${TARGET}"
GENERATED_KUSTOMIZATION="${OVERLAY}/kustomization.yaml"

{
  echo "# Generated by bin/deploy — do not edit manually."
  echo "# Build: ${MANIFEST_TAG} ($(date -u +%Y-%m-%dT%H:%M:%SZ))"
  echo "apiVersion: kustomize.config.k8s.io/v1beta1"
  echo "kind: Kustomization"
  echo ""
  echo "resources:"
  echo "  - ../../manifests"
  echo ""
  echo "images:"

  python3 -c "
import json
m = json.load(open('${MANIFEST}'))
for svc, info in m['services'].items():
    img = info['image']
    tag = info['tag']
    # image_name is registry/repo:tag — split into name and tag
    name_part = img.rsplit(':', 1)[0]
    # For kind: name stays as weaveworksdemos/<svc>, we only set newTag
    # For eks: name changes to ECR URI, we set both newName and newTag
    if '${TARGET}' == 'kind':
        print(f'  - name: weaveworksdemos/{svc}')
        print(f'    newTag: \"{tag}\"')
    else:
        print(f'  - name: weaveworksdemos/{svc}')
        print(f'    newName: {name_part}')
        print(f'    newTag: \"{tag}\"')
"
} > "$GENERATED_KUSTOMIZATION"

echo "Generated ${GENERATED_KUSTOMIZATION}"

# --- Apply --------------------------------------------------------------------

echo ""
echo "Applying with Kustomize overlay (${TARGET})..."
kubectl apply -k "${OVERLAY}"

echo ""
echo "Restarting deployments to pick up latest images..."
for dep in "${APP_DEPLOYMENTS[@]}"; do
  kubectl rollout restart deployment/"${dep}" -n "${NAMESPACE}"
done

echo ""
echo "Waiting for deployments to roll out..."
for dep in "${APP_DEPLOYMENTS[@]}"; do
  echo "  Waiting for ${dep}..."
  kubectl rollout status deployment/"${dep}" -n "${NAMESPACE}" --timeout=300s 2>/dev/null || \
    echo "  WARNING: ${dep} did not become ready within 300s"
done

echo ""
echo "Deployment complete."
echo ""
echo "Current status:"
kubectl get pods -n "${NAMESPACE}"
echo ""
echo "Images in use:"
kubectl get deployments -n "${NAMESPACE}" \
  -o jsonpath='{range .items[*]}{.metadata.name}{"\t"}{.spec.template.spec.containers[0].image}{"\n"}{end}' | column -t
echo ""
echo "To access the front-end: ./bin/port-forward"
