#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEMO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
REPO_ROOT="$(cd "${DEMO_DIR}/.." && pwd)"
KIND_CLUSTER="${KIND_CLUSTER:-qw}"
TAG="${1:-latest}"

echo "==> Building checkout-injector image..."
docker build -t "weaveworksdemos/checkout-injector:${TAG}" \
  -f "${DEMO_DIR}/Dockerfile.checkout-injector" "${REPO_ROOT}"
kind load docker-image "weaveworksdemos/checkout-injector:${TAG}" --name "${KIND_CLUSTER}"
echo "Build complete: weaveworksdemos/checkout-injector:${TAG}"
