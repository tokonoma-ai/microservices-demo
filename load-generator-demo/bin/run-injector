#!/usr/bin/env bash
# Run checkout-injector locally (for testing).
# Requires sock-shop services reachable (port-forward or full cluster).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

cd "${REPO_ROOT}"
python3 load-generator-demo/checkout_injector.py
